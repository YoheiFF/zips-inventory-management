# アプリケーション設定
NODE_ENV=production
PORT=3001

# データベース接続設定
# VPS本番(MariaDB直接): DB_PORT=3306
# VPS本番(Docker MySQL): DB_PORT=3309
# ローカル開発: DB_PORT=3308
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=zips_app
DB_PASS=（本番用パスワードを設定）
DB_NAME=Zips

# セッション設定
# 本番では必ず長いランダム文字列を設定すること
# 生成例: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=（長いランダム文字列を設定）

# セキュアCookie設定（HTTPS運用時のみ true に設定）
# HTTP運用（IP直アクセス等）の場合は false のままにすること
COOKIE_SECURE=false

# 管理者アカウント初期設定
# 本番では必ずデフォルト値から変更すること
ADMIN_USERNAME=admin
ADMIN_PASSWORD=（本番用強力なパスワードを設定）
